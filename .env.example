# GitHub token (required for private repos; public repos get 60 req/hr without it)
export GITHUB_TOKEN=""

# ── LLM Provider API Keys ────────────────────────────────────────────────────
# LiteLLM reads the standard provider env vars automatically.
# Set the key for whichever provider your config.yaml model points to.

# OpenAI
export OPENAI_API_KEY=""

# Anthropic
export ANTHROPIC_API_KEY=""

# Google Gemini
export GEMINI_API_KEY=""

# Groq
export GROQ_API_KEY=""

# OpenRouter — proxy for many models  (https://openrouter.ai/)
export OPENROUTER_API_KEY=""

# Override the API base URL (useful for local Ollama or custom proxies)
# export LLM_BASE_URL="http://localhost:11434"

# Set to any value to enable debug tracebacks
# export DEBUG=1
