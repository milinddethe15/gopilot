+func TestDNSLabelFormatValidation(t *testing.T) {
+	tests := []struct {
+		value    string `validate:"dns_label"`
+		tag      string
+		expected bool
+	}{
+		{"abc", "dns_label", true},
+		{"ABC", "dns_label", true},
+		{"abc-123", "dns_label", true},
+		{"ABC-123", "dns_label", true},
+		{"123-abc", "dns_label", true},
+		{"1", "dns_label", true},
+		{"abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijk", "dns_label", true},
+		{"", "dns_label", false},
+		{"abc-", "dns_label", false},
+		{"-abc", "dns_label", false},
+		{"abc.def", "dns_label", false},
+		{"test.example.com", "dns_label", false},
+		{"abc..def", "dns_label", false},
+		{"test_example", "dns_label", false},
+		{"foo bar", "dns_label", false},
+		{"foo/bar", "dns_label", false},
+		{"foo$", "dns_label", false},
+		{"abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijkl", "dns_label", false},
+	}
+
+	validate := New()
+
+	for i, test := range tests {
+		errs := validate.Var(test.value, test.tag)
+
+		if test.expected {
+			if !IsEqual(errs, nil) {
+				t.Fatalf("Index: %d dns_label failed Error: %s", i, errs)
+			}
+		} else {
+			if IsEqual(errs, nil) {
+				t.Fatalf("Index: %d dns_label failed Error: %s", i, errs)
+			} else {
+				val := getError(errs, "", "")
+				if val.Tag() != "dns_label" {
+					t.Fatalf("Index: %d dns_label failed Error: %s", i, errs)
+				}
+			}
+		}
+	}
+}
